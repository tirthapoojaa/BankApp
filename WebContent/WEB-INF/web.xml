<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Banking Application</display-name>

    <!-- Bank Servlet -->
    <servlet>
        <servlet-name>BankServlet</servlet-name>
        <servlet-class>servlet.BankServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BankServlet</servlet-name>
        <url-pattern>/api/bank</url-pattern>
    </servlet-mapping>

    <!-- Branch Servlet -->
    <servlet>
        <servlet-name>BranchServlet</servlet-name>
        <servlet-class>servlet.BranchServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BranchServlet</servlet-name>
        <url-pattern>/api/branch</url-pattern>
    </servlet-mapping>

    <!-- Customer Servlet -->
    <servlet>
        <servlet-name>CustomerServlet</servlet-name>
        <servlet-class>servlet.CustomerServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CustomerServlet</servlet-name>
        <url-pattern>/api/customer</url-pattern>
    </servlet-mapping>

    <!-- Account Servlet -->
    <servlet>
        <servlet-name>AccountServlet</servlet-name>
        <servlet-class>servlet.AccountServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AccountServlet</servlet-name>
        <url-pattern>/api/account</url-pattern>
    </servlet-mapping>

    <!-- Transaction Servlet -->
    <servlet>
        <servlet-name>TransactionServlet</servlet-name>
        <servlet-class>servlet.TransactionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TransactionServlet</servlet-name>
        <url-pattern>/api/transaction</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>
</web-app>
